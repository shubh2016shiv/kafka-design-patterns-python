# Stage 0.1 - Environment Defaults:
# This file provides safe defaults for local machines and single VM setups.

# Hostname/IP accessible by producers/consumers outside Docker.
KAFKA_EXTERNAL_HOST=localhost

# Exposed ports on the VM/host.
KAFKA_EXTERNAL_PORT=9094
KAFKA_INTERNAL_PORT=9092
KAFKA_UI_PORT=8080

# Kafka server behavior.
KAFKA_AUTO_CREATE_TOPICS=false
KAFKA_DEFAULT_PARTITIONS=3

# JVM sizing (tune for your VM sizing policy).
KAFKA_JVM_XMS=512m
KAFKA_JVM_XMX=1024m

# Keep this stable once data exists, otherwise metadata mismatches can occur.
KAFKA_KRAFT_CLUSTER_ID=MDEyMzQ1Njc4OTEyMzQ2Nw
